{
  "info": {
    "name": "HunarmandAI — Seller",
    "description": "All endpoints require a Seller session (Bearer JWT from OTP login) unless marked public. Every route below except /auth/otp/* is gated by authenticateUser + requireRole(seller) at the router level.",
