  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "POST /auth/otp/request",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/seller/auth/otp/request",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "seller",
                "auth",
                "otp",
                "request"
              ]
            },
            "description": "Request OTP\n\nSRS ref: UC-01, FR-1-01, FR-1-04\n\nCreates the seller account on first contact (role selection happens client-side before this call). Rate-limited to 3 requests / 10 min per phone.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"+923001234567\",\n  \"preferredLanguage\": \"ur\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status is 200 or documented error\", () => {",
                  "    pm.expect([200, 201, 400, 401, 403, 404, 409, 429].includes(pm.response.code)).to.be.true;",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /auth/otp/verify",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/seller/auth/otp/verify",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "seller",
                "auth",
                "otp",
                "verify"
              ]
            },
            "description": "Verify OTP and log in\n\nSRS ref: UC-01, FR-1-02, FR-1-03\n\nRate-limited to 5 attempts / 15 min per phone (lockout on the 6th). Returns a JWT valid for 7 days by default.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"+923001234567\",\n  \"code\": \"123456\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.success && res.data && res.data.token) {",
                  "    const role = pm.request.url.path.includes(\"seller\") ? \"seller_token\" : \"buyer_token\";",
                  "    pm.collectionVariables.set(role, res.data.token);",
                  "    if (res.data.seller) pm.collectionVariables.set(\"seller_id\", res.data.seller.id);",
                  "    if (res.data.buyer) pm.collectionVariables.set(\"buyer_id\", res.data.buyer.id);",
                  "    console.log(\"Saved token to collection variable: \" + role);",
                  "}",
                  "pm.test(\"Status is 200\", () => pm.response.to.have.status(200));"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /auth/logout",
          "request": {
            "method": "POST",
            "header": [],
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{seller_token}}",
                  "type": "string"
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/api/seller/auth/logout",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "seller",
                "auth",
                "logout"
              ]
            },
            "description": "Logout (revokes current token)\n\nSRS ref: UC-01\n\nAdds this specific token’s jti to the revocation list — a real server-side logout, not just client-side token deletion."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status is 200 or documented error\", () => {",
                  "    pm.expect([200, 201, 400, 401, 403, 404, 409, 429].includes(pm.response.code)).to.be.true;",
                  "});"
                ]
              }
            }
          ]
        }
      ]
