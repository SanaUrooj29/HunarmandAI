    {
      "name": "Checkout",
      "item": [
        {
          "name": "POST /checkout/initiate",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "auth": {
              "type": "bearer",
