        {
          "name": "POST /reviews",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{buyer_token}}",
                  "type": "string"
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/api/reviews",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "reviews"
              ]
            },
            "description": "Submit a review\n\nSRS ref: FR-6-04\n\nOnly allowed if the buyer has a delivered order containing this product.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": \"{{product_id}}\",\n  \"orderId\": \"{{order_id}}\",\n  \"rating\": 5,\n  \"comment\": \"Beautiful craftsmanship, exactly as pictured!\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status is 201 or documented error\", () => {",
                  "    pm.expect([200, 201, 400, 401, 403, 404, 409, 429].includes(pm.response.code)).to.be.true;",
                  "});"
                ]
              }
            }
          ]
        },
